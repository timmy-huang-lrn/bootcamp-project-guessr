<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Office GeoGuessr</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
    <script src="//items.staging.learnosity.com/?latest-lts"></script>
<style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
        --bg-deep: #0f1117;
        --bg-surface: #181b24;
        --bg-card: #1e2230;
        --grid-line: rgba(107, 192, 75, 0.06);
        --grid-line-accent: rgba(107, 192, 75, 0.12);
        --text-primary: #e8eaf0;
        --text-muted: #8b90a0;
        --text-dim: #555a6e;
        --green: #6bc04b;
        --green-glow: rgba(107, 192, 75, 0.3);
        --yellow: #f5d547;
        --blue: #4a90d9;
        --red: #e74c3c;
    }

    body {
        font-family: 'Outfit', sans-serif;
        background-color: var(--bg-deep);
        color: var(--text-primary);
        min-height: 100vh;
        overflow-x: hidden;
        background-image:
            linear-gradient(var(--grid-line) 1px, transparent 1px),
            linear-gradient(90deg, var(--grid-line) 1px, transparent 1px),
            linear-gradient(var(--grid-line-accent) 1px, transparent 1px),
            linear-gradient(90deg, var(--grid-line-accent) 1px, transparent 1px);
        background-size: 20px 20px, 20px 20px, 100px 100px, 100px 100px;
        background-position: center center;
    }

    /* ========== HEADER ========== */
    .header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 24px;
        background: var(--bg-card);
        border-bottom: 2px solid var(--green);
        opacity: 0;
        transform: translateY(-12px);
        animation: headerIn 0.4s ease 0.1s forwards;
    }

    @keyframes headerIn {
        to { opacity: 1; transform: translateY(0); }
    }

    .header-brand {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .header-pin { width: 28px; height: 36px; flex-shrink: 0; }

    .header-title {
        font-weight: 800;
        font-size: 20px;
        letter-spacing: -0.5px;
        color: var(--text-primary);
    }

    .header-status {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--text-muted);
    }

    .status-dot {
        width: 8px; height: 8px;
        background: var(--green);
        border-radius: 50%;
        animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; box-shadow: 0 0 0 0 var(--green-glow); }
        50% { opacity: 0.7; box-shadow: 0 0 0 6px transparent; }
    }

    /* ========== QUIZ CONTAINER ========== */
    .quiz-wrapper {
        max-width: 960px;
        margin: 0 auto;
        padding: 32px 24px 80px;
        position: relative;
        opacity: 0;
        transform: translateY(16px);
        animation: quizIn 0.4s ease 0.3s forwards;
    }

    @keyframes quizIn {
        to { opacity: 1; transform: translateY(0); }
    }

    .quiz-container {
        background: var(--bg-surface);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        padding: 28px;
        position: relative;
        z-index: 1;
    }

    /* ========== TIMER BAR ========== */
    .timer-bar-wrapper {
        position: sticky;
        top: 0;
        z-index: 100;
        background: var(--bg-deep);
        padding: 12px 24px 0;
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    .timer-bar-wrapper.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .timer-bar {
        display: flex;
        align-items: center;
        gap: 14px;
        background: var(--bg-card);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 12px;
        padding: 14px 20px;
        margin-top: 24px;
    }

    .timer-icon {
        width: 22px; height: 22px;
        flex-shrink: 0;
        opacity: 0.7;
    }

    .timer-track {
        flex: 1;
        height: 6px;
        background: rgba(255, 255, 255, 0.06);
        border-radius: 3px;
        overflow: hidden;
        position: relative;
    }

    .timer-fill {
        height: 100%;
        width: 100%;
        border-radius: 3px;
        background: var(--green);
        transform-origin: left center;
        transition: background 0.3s ease;
    }
    .timer-fill.warning { background: var(--yellow); }
    .timer-fill.danger { background: var(--red); }

    .timer-digits {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 16px;
        font-weight: 600;
        min-width: 38px;
        text-align: right;
        color: var(--text-primary);
        transition: color 0.3s ease;
    }
    .timer-digits.warning { color: var(--yellow); }
    .timer-digits.danger { color: var(--red); }

    .timer-question-label {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--text-dim);
        flex-shrink: 0;
    }

    /* Time's up flash */
    .timer-bar.times-up {
        animation: timesUpFlash 0.5s ease;
    }
    @keyframes timesUpFlash {
        0%, 100% { border-color: rgba(255, 255, 255, 0.06); }
        30% { border-color: var(--red); }
        60% { border-color: rgba(231, 76, 60, 0.3); }
    }

    .times-up-label {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--red);
        display: none;
    }
    .timer-bar.times-up .times-up-label { display: block; }
    .timer-bar.times-up .timer-digits { display: none; }

    /* ========== COMPASS WATERMARK ========== */
    .watermark {
        position: fixed;
        bottom: 24px;
        right: 24px;
        width: 180px;
        height: 180px;
        opacity: 0.03;
        pointer-events: none;
        z-index: 0;
    }

    /* ========== VIGNETTE ========== */
    body::after {
        content: '';
        position: fixed;
        inset: 0;
        background: radial-gradient(ellipse at center, transparent 50%, rgba(0, 0, 0, 0.4) 100%);
        pointer-events: none;
        z-index: 0;
    }

    /* ========== RESPONSIVE ========== */
    @media (max-width: 640px) {
        .header { padding: 12px 16px; }
        .header-title { font-size: 17px; }
        .header-status { font-size: 11px; }
        .timer-bar-wrapper { padding: 0 12px; }
        .timer-bar { padding: 10px 14px; gap: 10px; }
        .timer-digits { font-size: 14px; }
        .quiz-wrapper { padding: 20px 12px 60px; }
        .quiz-container { padding: 16px; border-radius: 12px; }
        .watermark { width: 120px; height: 120px; bottom: 12px; right: 12px; }
    }
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
    <div class="header-brand">
        <svg class="header-pin" viewBox="0 0 28 36" xmlns="http://www.w3.org/2000/svg">
            <path d="M14 0C6.268 0 0 6.268 0 14c0 10 14 22 14 22s14-12 14-22C28 6.268 21.732 0 14 0z" fill="var(--green)" opacity="0.9"/>
            <circle cx="14" cy="13" r="6" fill="rgba(0,0,0,0.25)"/>
            <circle cx="14" cy="13" r="5" fill="var(--bg-card)"/>
            <text x="14" y="15.5" text-anchor="middle" font-family="Outfit,sans-serif" font-weight="800" font-size="7" fill="var(--green)">★</text>
        </svg>
        <span class="header-title">Office GeoGuessr</span>
    </div>
    <div class="header-status">
        <span class="status-dot"></span>
        <span>Round in Progress</span>
    </div>
</div>

<!-- TIMER -->
<div class="timer-bar-wrapper" id="timer-wrapper">
    <div class="timer-bar" id="timer-bar">
        <svg class="timer-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="13" r="9" stroke="var(--text-muted)" stroke-width="1.5"/>
            <line x1="12" y1="13" x2="12" y2="8" stroke="var(--text-primary)" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="12" y1="13" x2="15" y2="13" stroke="var(--text-muted)" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="12" y1="2" x2="12" y2="4" stroke="var(--text-muted)" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="9" y1="2" x2="15" y2="2" stroke="var(--text-muted)" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span class="timer-question-label" id="timer-q-label">Q1</span>
        <div class="timer-track">
            <div class="timer-fill" id="timer-fill"></div>
        </div>
        <span class="timer-digits" id="timer-digits">15</span>
        <span class="times-up-label">Time's up!</span>
    </div>
</div>

<!-- QUIZ -->
<div class="quiz-wrapper">
    <div class="quiz-container">
        <div id="learnosity_assess"></div>
    </div>
</div>

<!-- COMPASS WATERMARK -->
<svg class="watermark" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
    <circle cx="100" cy="100" r="90" fill="none" stroke="var(--text-primary)" stroke-width="2"/>
    <circle cx="100" cy="100" r="70" fill="none" stroke="var(--text-primary)" stroke-width="1"/>
    <line x1="100" y1="5" x2="100" y2="30" stroke="var(--text-primary)" stroke-width="2.5" stroke-linecap="round"/>
    <line x1="100" y1="170" x2="100" y2="195" stroke="var(--text-primary)" stroke-width="2.5" stroke-linecap="round"/>
    <line x1="5" y1="100" x2="30" y2="100" stroke="var(--text-primary)" stroke-width="2.5" stroke-linecap="round"/>
    <line x1="170" y1="100" x2="195" y2="100" stroke="var(--text-primary)" stroke-width="2.5" stroke-linecap="round"/>
    <polygon points="100,15 94,50 106,50" fill="var(--red)" opacity="0.8"/>
    <polygon points="100,185 94,150 106,150" fill="var(--text-muted)" opacity="0.5"/>
    <text x="100" y="22" text-anchor="middle" font-family="IBM Plex Mono,monospace" font-size="10" font-weight="600" fill="var(--text-primary)">N</text>
    <circle cx="100" cy="100" r="5" fill="var(--text-primary)"/>
</svg>

<script>
    const TIMER_DURATION = 15; // seconds per question
    let timerInterval = null;
    let timeLeft = TIMER_DURATION;
    let questionsLeft = 5;

    const timerWrapper = document.getElementById('timer-wrapper');
    const timerBar = document.getElementById('timer-bar');
    const timerFill = document.getElementById('timer-fill');
    const timerDigits = document.getElementById('timer-digits');
    const timerQLabel = document.getElementById('timer-q-label');

    function resetTimer(questionNum) {
        // Clear previous
        clearInterval(timerInterval);
        timeLeft = TIMER_DURATION;

        if (questionsLeft === 0) {
            document.getElementById("timer-wrapper").style.display = "none";
        } else {
            questionsLeft = questionsLeft - 1;
        }

        // Reset UI
        timerBar.classList.remove('times-up');
        timerFill.classList.remove('warning', 'danger');
        timerDigits.classList.remove('warning', 'danger');
        timerFill.style.transform = 'scaleX(1)';
        timerDigits.textContent = TIMER_DURATION;
        timerQLabel.textContent = 'Q' + questionNum;

        // Start countdown
        const startTime = Date.now();
        const endTime = startTime + TIMER_DURATION * 1000;

        timerInterval = setInterval(() => {
            const now = Date.now();
            const remaining = Math.max(0, endTime - now);
            const remainingSec = Math.ceil(remaining / 1000);
            const fraction = remaining / (TIMER_DURATION * 1000);

            // Update bar
            timerFill.style.transform = 'scaleX(' + fraction + ')';
            timerDigits.textContent = remainingSec;

            // Color thresholds
            if (remainingSec <= 3) {
                timerFill.classList.remove('warning');
                timerFill.classList.add('danger');
                timerDigits.classList.remove('warning');
                timerDigits.classList.add('danger');
            } else if (remainingSec <= 5) {
                timerFill.classList.remove('danger');
                timerFill.classList.add('warning');
                timerDigits.classList.remove('danger');
                timerDigits.classList.add('warning');
            } else {
                timerFill.classList.remove('warning', 'danger');
                timerDigits.classList.remove('warning', 'danger');
            }

            // Time's up
            if (remaining <= 0) {
                clearInterval(timerInterval);
                timerBar.classList.add('times-up');
                timerFill.style.transform = 'scaleX(0)';
            }
        }, 50);
    }

    function stopTimer() {
        clearInterval(timerInterval);
    }

    const request = <%- JSON.stringify(request) %>;
    const itemsApp = LearnosityItems.init(request, {
        readyListener() {
            console.log('Learnosity ready');

            // Show the timer and start for first question
            timerWrapper.classList.add('visible');
            // resetTimer(1);

            // Listen for question changes
            itemsApp.on('item:changed', function (itemIndex) {
                resetTimer(itemIndex + 1);
            });
        },
        errorListener(err) {
            console.error('Learnosity error', err);
        }
    });
</script>
</body>
</html>
