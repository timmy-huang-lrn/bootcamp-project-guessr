<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Office GeoGuessr — Results</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
    <script src="//reports.staging.learnosity.com/?latest-lts"></script>
<style>
    /* ========== RESET & BASE ========== */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
        --bg-deep: #0f1117;
        --bg-surface: #181b24;
        --bg-card: #1e2230;
        --grid-line: rgba(107, 192, 75, 0.06);
        --grid-line-accent: rgba(107, 192, 75, 0.12);
        --text-primary: #e8eaf0;
        --text-muted: #8b90a0;
        --text-dim: #555a6e;
        --green: #6bc04b;
        --green-glow: rgba(107, 192, 75, 0.3);
        --yellow: #f5d547;
        --blue: #4a90d9;
        --red: #e74c3c;
        --gold: #ffd700;
        --gold-glow: rgba(255, 215, 0, 0.35);
        --silver: #c0c7d0;
        --silver-glow: rgba(192, 199, 208, 0.25);
        --bronze: #cd7f32;
        --bronze-glow: rgba(205, 127, 50, 0.25);
        --ring-size: 220px;
        --ring-stroke: 12;
    }

    body {
        font-family: 'Outfit', sans-serif;
        background-color: var(--bg-deep);
        color: var(--text-primary);
        min-height: 100vh;
        overflow-x: hidden;
        background-image:
            linear-gradient(var(--grid-line) 1px, transparent 1px),
            linear-gradient(90deg, var(--grid-line) 1px, transparent 1px),
            linear-gradient(var(--grid-line-accent) 1px, transparent 1px),
            linear-gradient(90deg, var(--grid-line-accent) 1px, transparent 1px);
        background-size: 20px 20px, 20px 20px, 100px 100px, 100px 100px;
        background-position: center center;
    }

    .page-wrapper {
        max-width: 620px;
        margin: 0 auto;
        padding: 48px 24px 80px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    /* ========== CONFETTI ========== */
    #confetti-canvas {
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        pointer-events: none;
        z-index: 1000;
    }

    /* ========== LOADER ========== */
    .loader-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        gap: 28px;
        transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .loader-section.fade-out {
        opacity: 0;
        transform: translateY(-20px);
        pointer-events: none;
    }
    .loader-section.hidden { display: none; }

    .compass-spinner {
        width: 80px; height: 80px;
        animation: spin 2s cubic-bezier(0.45, 0.05, 0.55, 0.95) infinite;
    }
    .compass-spinner .c-body { fill: none; stroke: var(--text-dim); stroke-width: 2; }
    .compass-spinner .c-needle-n { fill: var(--red); }
    .compass-spinner .c-needle-s { fill: var(--text-muted); }
    .compass-spinner .c-center { fill: var(--text-primary); }

    .loader-text {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 14px;
        color: var(--text-muted);
        letter-spacing: 0.5px;
    }
    .loader-text::after { content: ''; animation: ellipsis 1.5s steps(4, end) infinite; }

    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes ellipsis {
        0%  { content: ''; }
        25% { content: '.'; }
        50% { content: '..'; }
        75% { content: '...'; }
    }

    /* ========== RESULTS ========== */
    .results-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .results-container.visible { opacity: 1; transform: translateY(0); }

    /* ========== SCORE RING ========== */
    .score-ring-wrapper {
        position: relative;
        width: var(--ring-size); height: var(--ring-size);
        margin-bottom: 12px;
    }
    .score-ring-svg {
        width: 100%; height: 100%;
        transform: rotate(-90deg);
    }
    .ring-bg {
        fill: none;
        stroke: var(--bg-card);
        stroke-width: var(--ring-stroke);
    }
    .ring-progress {
        fill: none;
        stroke: var(--green);
        stroke-width: var(--ring-stroke);
        stroke-linecap: round;
        transition: stroke-dashoffset 1.5s cubic-bezier(0.4, 0, 0.2, 1), stroke 0.3s ease;
    }
    .ring-glow {
        fill: none;
        stroke: var(--green-glow);
        stroke-width: calc(var(--ring-stroke) + 8);
        stroke-linecap: round;
        filter: blur(6px);
        opacity: 0.6;
        transition: stroke-dashoffset 1.5s cubic-bezier(0.4, 0, 0.2, 1), stroke 0.3s ease;
    }
    .score-overlay {
        position: absolute; inset: 0;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
    }
    .score-percent {
        font-family: 'Outfit', sans-serif;
        font-weight: 900;
        font-size: 52px;
        line-height: 1;
        letter-spacing: -2px;
    }
    .score-pct-sign {
        font-size: 28px; font-weight: 600;
        color: var(--text-muted);
        margin-left: 2px;
    }
    .score-sub {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 13px;
        color: var(--text-muted);
        margin-top: 4px;
    }

    /* ========== TIER BADGE ========== */
    .tier-badge {
        margin-top: 36px;
        text-align: center;
        opacity: 0;
        transform: scale(0.8) translateY(10px);
        transition: opacity 0.4s ease, transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .tier-badge.visible { opacity: 1; transform: scale(1) translateY(0); }

    .tier-pin {
        width: 56px; height: 56px;
        margin: 0 auto 16px;
    }
    .tier-pin svg { width: 100%; height: 100%; }

    .tier-title {
        font-weight: 900;
        font-size: 36px;
        line-height: 1.1;
        letter-spacing: -1px;
        margin-bottom: 8px;
    }
    .tier-tagline {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 15px;
        font-style: italic;
        color: var(--text-muted);
    }

    /* ========== MESSAGE CARD ========== */
    .msg-card {
        margin-top: 32px;
        background: var(--bg-card);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 16px;
        padding: 28px 32px;
        width: 100%; max-width: 480px;
        opacity: 0;
        transform: translateY(15px);
        transition: opacity 0.4s ease, transform 0.4s ease;
        position: relative;
        overflow: hidden;
    }
    .msg-card.visible { opacity: 1; transform: translateY(0); }
    .msg-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        border-radius: 16px 16px 0 0;
        background: var(--green);
        transition: background 0.3s ease;
    }
    .msg-card-text {
        font-size: 16px;
        line-height: 1.65;
        color: var(--text-primary);
    }

    /* ========== DEBRIEF ========== */
    .debrief {
        margin-top: 56px;
        width: 100%;
        opacity: 0;
        transform: translateY(15px);
        transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .debrief.visible { opacity: 1; transform: translateY(0); }
    .debrief-label {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--text-dim);
        margin-bottom: 20px;
        padding: 6px 14px;
        border: 1px dashed var(--text-dim);
        border-radius: 4px;
    }
    #session-detail {
        background: var(--bg-surface);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 12px;
        padding: 24px;
        overflow: auto;
    }

    /* ========== TIER THEME OVERRIDES ========== */
    .tier-legend .score-percent { color: var(--gold); text-shadow: 0 0 30px var(--gold-glow); }
    .tier-legend .ring-progress { stroke: var(--gold); }
    .tier-legend .ring-glow { stroke: var(--gold-glow); }
    .tier-legend .tier-title { color: var(--gold); }
    .tier-legend .msg-card::before { background: var(--gold); }
    .tier-legend .tier-pin { filter: drop-shadow(0 0 12px var(--gold-glow)); }

    .tier-veteran .score-percent { color: var(--silver); }
    .tier-veteran .ring-progress { stroke: var(--silver); }
    .tier-veteran .ring-glow { stroke: var(--silver-glow); }
    .tier-veteran .tier-title { color: var(--silver); }
    .tier-veteran .msg-card::before { background: var(--silver); }

    .tier-detective .score-percent { color: var(--bronze); }
    .tier-detective .ring-progress { stroke: var(--bronze); }
    .tier-detective .ring-glow { stroke: var(--bronze-glow); }
    .tier-detective .tier-title { color: var(--bronze); }
    .tier-detective .msg-card::before { background: var(--bronze); }

    .tier-regular .score-percent { color: var(--green); }
    .tier-regular .tier-title { color: var(--green); }

    .tier-newhire .score-percent { color: var(--blue); }
    .tier-newhire .ring-progress { stroke: var(--blue); }
    .tier-newhire .ring-glow { stroke: rgba(74,144,217,0.3); }
    .tier-newhire .tier-title { color: var(--blue); }
    .tier-newhire .msg-card::before { background: var(--blue); }

    .tier-intern .score-percent { color: var(--yellow); }
    .tier-intern .ring-progress { stroke: var(--yellow); }
    .tier-intern .ring-glow { stroke: rgba(245,213,71,0.25); }
    .tier-intern .tier-title { color: var(--yellow); }
    .tier-intern .msg-card::before { background: var(--yellow); }

    @keyframes legendPulse {
        0%, 100% { filter: drop-shadow(0 0 12px var(--gold-glow)); }
        50% { filter: drop-shadow(0 0 24px var(--gold-glow)) drop-shadow(0 0 48px rgba(255,215,0,0.15)); }
    }
    .tier-legend .tier-pin { animation: legendPulse 2s ease-in-out infinite; }

    /* ========== RESPONSIVE ========== */
    @media (max-width: 480px) {
        .page-wrapper { padding: 32px 16px 60px; }
        :root { --ring-size: 180px; }
        .score-percent { font-size: 42px; }
        .tier-title { font-size: 28px; }
        .msg-card { padding: 22px 20px; }
    }
</style>
</head>
<body>
<canvas id="confetti-canvas"></canvas>

<div class="page-wrapper">

    <!-- LOADER -->
    <div class="loader-section" id="loader">
        <svg class="compass-spinner" viewBox="0 0 80 80">
            <circle class="c-body" cx="40" cy="40" r="34"/>
            <line x1="40" y1="8" x2="40" y2="14" stroke="var(--text-muted)" stroke-width="2" stroke-linecap="round"/>
            <line x1="40" y1="66" x2="40" y2="72" stroke="var(--text-muted)" stroke-width="2" stroke-linecap="round"/>
            <line x1="8" y1="40" x2="14" y2="40" stroke="var(--text-muted)" stroke-width="2" stroke-linecap="round"/>
            <line x1="66" y1="40" x2="72" y2="40" stroke="var(--text-muted)" stroke-width="2" stroke-linecap="round"/>
            <polygon class="c-needle-n" points="40,12 36,40 44,40"/>
            <polygon class="c-needle-s" points="40,68 36,40 44,40"/>
            <circle class="c-center" cx="40" cy="40" r="4"/>
        </svg>
        <span class="loader-text">Calculating your office navigation skills</span>
    </div>

    <!-- RESULTS -->
    <div class="results-container" id="results">

        <div class="score-ring-wrapper">
            <svg class="score-ring-svg" viewBox="0 0 220 220">
                <circle class="ring-bg" cx="110" cy="110" r="100"/>
                <circle class="ring-glow" cx="110" cy="110" r="100"
                    id="ring-glow" stroke-dasharray="628.32" stroke-dashoffset="628.32"/>
                <circle class="ring-progress" cx="110" cy="110" r="100"
                    id="ring-progress" stroke-dasharray="628.32" stroke-dashoffset="628.32"/>
            </svg>
            <div class="score-overlay">
                <div>
                    <span class="score-percent" id="score-num">0</span><span class="score-pct-sign">%</span>
                </div>
                <div class="score-sub" id="score-sub">— / — correct</div>
            </div>
        </div>

        <div class="tier-badge" id="tier-badge">
            <div class="tier-pin" id="tier-pin"></div>
            <div class="tier-title" id="tier-title"></div>
            <div class="tier-tagline" id="tier-tagline"></div>
        </div>

        <div class="msg-card" id="msg-card">
            <p class="msg-card-text" id="msg-text"></p>
        </div>

        <div class="debrief" id="debrief">
            <div class="debrief-label">📋 Full Debrief</div>
            <div id="session-detail"></div>
        </div>

    </div>
</div>

<script>
    /* ===== TIER DEFINITIONS ===== */
    const TIERS = [
        { min: 95, css: 'tier-legend', title: 'Office Legend',
          tagline: "They'll name a meeting room after you.",
          msg: "Pack up your desk — you've been promoted to CEO of Knowing Things. The corner office is yours.",
          pin: '#ffd700', confetti: true },
        { min: 90, css: 'tier-veteran', title: 'Office Veteran',
          tagline: 'You could navigate blindfolded.',
          msg: "HR wants to know your secret. Legal wants to know if you've been reading classified memos.",
          pin: '#c0c7d0', confetti: false },
        { min: 75, css: 'tier-detective', title: 'Desk Detective',
          tagline: 'Sharp eyes, sharp instincts.',
          msg: "Not bad. You clearly pay attention in those all-hands meetings. Or at least, you look like you do.",
          pin: '#cd7f32', confetti: false },
        { min: 50, css: 'tier-regular', title: 'Regular',
          tagline: 'You know your way around.',
          msg: "Solid effort. You know where the good coffee machine is and that's what really matters.",
          pin: '#6bc04b', confetti: false },
        { min: 25, css: 'tier-newhire', title: 'New Hire',
          tagline: 'Still learning the floor plan.',
          msg: "Week one energy. You'll get there — just follow the person who looks like they know where they're going.",
          pin: '#4a90d9', confetti: false },
        { min: 0, css: 'tier-intern', title: 'Intern (Lost)',
          tagline: 'Have you tried asking reception?',
          msg: "Don't worry, everyone gets lost on their first day. The kitchen is down the hall and to the left. Probably.",
          pin: '#f5d547', confetti: false }
    ];

    const getTier = pct => TIERS.find(t => pct >= t.min) || TIERS[TIERS.length - 1];

    const pinSVG = color => `<svg viewBox="0 0 56 72" xmlns="http://www.w3.org/2000/svg">
        <path d="M28 0C12.536 0 0 12.536 0 28c0 20 28 44 28 44s28-24 28-44C56 12.536 43.464 0 28 0z" fill="${color}" opacity="0.9"/>
        <circle cx="28" cy="26" r="12" fill="rgba(0,0,0,0.25)"/>
        <circle cx="28" cy="26" r="10" fill="#1e2230"/>
        <text x="28" y="31" text-anchor="middle" font-family="Outfit,sans-serif" font-weight="800" font-size="14" fill="${color}">★</text>
    </svg>`;

    /* ===== SCORE EXTRACTION ===== */
    function extractScores() {
        const spans = document.querySelectorAll('#session-detail .lrn-circle span');
        let earned = 0, possible = 0;
        spans.forEach(s => {
            const p = s.textContent.trim().split('/');
            if (p.length === 2) {
                const e = parseInt(p[0], 10), t = parseInt(p[1], 10);
                if (!isNaN(e) && !isNaN(t)) { earned += e; possible += t; }
            }
        });
        possible = 15;
        return { earned, possible, percent: possible > 0 ? Math.round((earned / possible) * 100) : 0 };
    }

    /* ===== ANIMATIONS ===== */
    function countUp(target, duration, el) {
        const t0 = performance.now();
        (function tick(now) {
            const p = Math.min((now - t0) / duration, 1);
            el.textContent = Math.round((1 - Math.pow(1 - p, 3)) * target);
            if (p < 1) requestAnimationFrame(tick);
        })(t0);
    }

    function animateRing(pct) {
        const c = 2 * Math.PI * 100;
        const off = c - (pct / 100) * c;
        requestAnimationFrame(() => {
            document.getElementById('ring-progress').style.strokeDashoffset = off;
            document.getElementById('ring-glow').style.strokeDashoffset = off;
        });
    }

    /* ===== CONFETTI ===== */
    function launchConfetti() {
        const cv = document.getElementById('confetti-canvas');
        const ctx = cv.getContext('2d');
        cv.width = window.innerWidth;
        cv.height = window.innerHeight;
        const cols = ['#ffd700','#f5d547','#6bc04b','#4a90d9','#e74c3c','#c0c7d0'];
        const P = [];
        for (let i = 0; i < 150; i++) P.push({
            x: cv.width/2 + (Math.random()-.5)*200, y: cv.height*.4,
            vx: (Math.random()-.5)*16, vy: -Math.random()*18 - 4,
            w: Math.random()*8+4, h: Math.random()*6+2,
            col: cols[Math.floor(Math.random()*cols.length)],
            rot: Math.random()*360, rs: (Math.random()-.5)*12,
            g: .35+Math.random()*.15, op: 1, dec: .003+Math.random()*.004
        });
        let raf;
        (function frame() {
            ctx.clearRect(0,0,cv.width,cv.height);
            let alive = false;
            for (const p of P) {
                if (p.op <= 0) continue;
                alive = true;
                p.vy += p.g; p.x += p.vx; p.y += p.vy;
                p.vx *= .98; p.rot += p.rs; p.op -= p.dec;
                ctx.save();
                ctx.translate(p.x, p.y);
                ctx.rotate(p.rot * Math.PI / 180);
                ctx.globalAlpha = Math.max(0, p.op);
                ctx.fillStyle = p.col;
                ctx.fillRect(-p.w/2, -p.h/2, p.w, p.h);
                ctx.restore();
            }
            if (alive) raf = requestAnimationFrame(frame);
        })();
        setTimeout(() => { cancelAnimationFrame(raf); ctx.clearRect(0,0,cv.width,cv.height); }, 5000);
    }

    /* ===== REVEAL ORCHESTRATOR ===== */
    function revealResults(scores, tier) {
        const results = document.getElementById('results');
        const loader = document.getElementById('loader');

        results.classList.add(tier.css);
        document.getElementById('tier-pin').innerHTML = pinSVG(tier.pin);
        document.getElementById('tier-title').textContent = tier.title;
        document.getElementById('tier-tagline').textContent = tier.tagline;
        document.getElementById('msg-text').textContent = tier.msg;
        document.getElementById('score-sub').textContent = scores.earned + ' / ' + scores.possible + ' correct';

        loader.classList.add('fade-out');
        setTimeout(() => {
            loader.classList.add('hidden');
            results.classList.add('visible');
            animateRing(scores.percent);
            countUp(scores.percent, 1500, document.getElementById('score-num'));

            setTimeout(() => {
                document.getElementById('tier-badge').classList.add('visible');
                setTimeout(() => {
                    document.getElementById('msg-card').classList.add('visible');
                    if (tier.confetti) setTimeout(launchConfetti, 200);
                    setTimeout(() => document.getElementById('debrief').classList.add('visible'), 400);
                }, 400);
            }, 1600);
        }, 450);
    }

    /* ===== EXTRACTION WITH RETRY + OBSERVER ===== */
    function attemptExtraction(retries) {
        const s = extractScores();
        if (s.possible > 0) return revealResults(s, getTier(s.percent));
        if (retries > 0) return setTimeout(() => attemptExtraction(retries - 1), 400);

        // Fallback: observe DOM mutations
        const target = document.getElementById('session-detail');
        const obs = new MutationObserver(() => {
            const s2 = extractScores();
            if (s2.possible > 0) { obs.disconnect(); revealResults(s2, getTier(s2.percent)); }
        });
        obs.observe(target, { childList: true, subtree: true });

        // Ultimate fallback — just show raw report
        setTimeout(() => {
            obs.disconnect();
            const s3 = extractScores();
            if (s3.possible > 0) return revealResults(s3, getTier(s3.percent));
            document.getElementById('loader').classList.add('fade-out');
            setTimeout(() => {
                document.getElementById('loader').classList.add('hidden');
                document.getElementById('results').classList.add('visible');
                document.getElementById('debrief').classList.add('visible');
            }, 450);
        }, 10000);
    }

    /* ===== LEARNOSITY INIT ===== */
    const request = <%- JSON.stringify(request) %>;
    const reportsApp = LearnosityReports.init(request, {
        readyListener() {
            console.log('Learnosity ready');
            setTimeout(() => attemptExtraction(5), 500);
        },
        errorListener(err) {
            console.error('Learnosity error', err);
        }
    });
</script>
</body>
</html>
